# Base URL de la API NestJS (backend)
# Por defecto: http://localhost:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Opcional: para login con Google, configurar cliente OAuth y obtener idToken
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Opcional: GIPHY API Key para GIFs de celebración al avanzar en lectura (https://developers.giphy.com/)
# EXPO_PUBLIC_GIPHY_API_KEY=your-giphy-api-key
